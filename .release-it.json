{
  "git": {
    "commitMessage": "chore: release v${version}",
    "requireBranch": "main"
  },
  "github": {
    "release": true
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": ["git pull", "npm run lint"]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "eslint"
      },
      "infile": "CHANGELOG.md"
    }
  }
}
